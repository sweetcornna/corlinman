# corlinman runtime secrets — fill the values, place at repo root as `.env`
#
# These flow into docker/compose/docker-compose.yml via `env_file`.
# `start.sh` resolves any `[providers.*].api_key = { env = "<KEY>" }`
# entries from `config.toml` against this file at boot.

# === LLM providers ==========================================================
# Fill at least one. The provider whose key is non-empty becomes the
# default at first chat unless a model alias points elsewhere.
OPENAI_API_KEY=
# Optional override (default api.openai.com). Useful for OpenAI-compatible
# proxies / local models that speak the OpenAI Chat Completions wire.
# OPENAI_BASE_URL=

GEMINI_API_KEY=
# Optional region override; default is the public Gemini endpoint.
# GEMINI_BASE_URL=

# SiliconFlow (硅基流动) — OpenAI-compatible Chinese cloud. Hosts Qwen,
# GLM, DeepSeek, Yi, plus embedding models like `Qwen/Qwen3-Embedding-4B`
# (2560-dim). Pair with `[providers.siliconflow]` + `kind = "openai_compatible"`
# in config.toml. Useful as the embedding backend so the evolution
# proposer's signal clustering runs entirely inside CN networking.
SILICONFLOW_API_KEY=

# === QQ channel (NapCat) ====================================================
# QQ is ON BY DEFAULT — docker mode brings up the NapCat sidecar, native
# mode provisions a NapCat AppImage + corlinman-napcat.service systemd unit.
# Opt out with `install.sh --without-qq`.
#
# NapCat handles the QQ login session; corlinman dials it via
# `CORLINMAN_NAPCAT_URL` (webui + scan-login HTTP API) and `QQ_WS_URL`
# (OneBot v11 forward-WS message bus). The installer sets sane defaults for
# each mode, so you normally don't need to set these by hand.
#
# Pin: keep NAPCAT_VERSION matched between the docker image
# (mlikiowa/napcat-docker:<tag>) and the native AppImage
# (github.com/NapNeko/NapCatAppImageBuild release <tag>). Default below is
# the known-good stable verified 2026-05-22.
NAPCAT_VERSION=v4.18.4
#
# Shared NapCat WebUI secret. Docker mode maps NAPCAT_WEBUI_TOKEN into
# NapCat's WEBUI_TOKEN automatically; native systemd mode reads WEBUI_TOKEN
# directly. Keep these equal if you rotate them.
NAPCAT_WEBUI_TOKEN=corlinman-local-napcat
WEBUI_TOKEN=corlinman-local-napcat
#
# CORLINMAN_NAPCAT_URL — NapCat webui + scan-login HTTP API.
#   docker : http://napcat:6099    (set by docker-compose.qq.yml)
#   native : http://127.0.0.1:6099 (set by the gateway systemd unit)
# CORLINMAN_NAPCAT_URL=http://127.0.0.1:6099
#
# QQ_WS_URL — OneBot v11 forward-WS bridge for the channel dispatcher.
#   docker : ws://napcat:3001      (set by docker-compose.qq.yml)
#   native : ws://127.0.0.1:3001   (set by the gateway systemd unit)
# QQ_WS_URL=ws://127.0.0.1:3001
#
# Optional: a comma-separated list of admin QQ ids that can run the
# in-band scan-login + provider-config flow over QQ. Empty = web admin only.
QQ_ADMIN_IDS=

# === Telegram channel =======================================================
# Bot token from @BotFather. Leave empty to skip telegram.
# To activate: paste token here, flip `[channels.telegram] enabled = true`
# in ~/.corlinman/config.toml, restart container.
TELEGRAM_BOT_TOKEN=
# Required only when switching to webhook mode (set `[telegram.webhook]
# public_url`). Any random string ≥ 16 chars. Webhook requests carry it in
# the `X-Telegram-Bot-Api-Secret-Token` header.
TELEGRAM_WEBHOOK_SECRET=

# === Admin web UI auth ======================================================
# Single-shot bootstrap token for the very first login at /admin. Rotate
# from the admin UI after that.
ADMIN_BOOTSTRAP_TOKEN=please-change-me

# === Logging ================================================================
# `info`, `debug`, `warn`. Increase to `debug` while iterating; default
# `info` keeps production logs readable.
RUST_LOG=info
